# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o-mini) — https://platform.openai.com
OPENAI_API_KEY=

# Groq (Llama 3.3 70B, free tier) — https://console.groq.com
GROQ_API_KEY=

# Ollama (local models: Qwen2.5, Llama 3.1, Gemma 2) — install from https://ollama.com
# No API key required. Only set this if Ollama runs on a non-default host/port.
OLLAMA_BASE_URL=http://localhost:11434
